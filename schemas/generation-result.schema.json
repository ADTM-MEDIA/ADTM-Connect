{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adtm.systems/schemas/connect-v2/generation-result.schema.json",
  "title": "ADTM Connect V2 - Résultat de génération",
  "type": "object",
  "additionalProperties": false,
  "required": ["id_execution", "id_support", "version", "statut_execution", "date_execution", "fichiers"],
  "properties": {
    "id_execution": { "type": "string", "minLength": 1, "maxLength": 100 },
    "id_support": { "type": "string", "pattern": "^[A-Z0-9]+-[A-Z]{2}[0-9]{2}$" },
    "version": { "type": "integer", "minimum": 1 },
    "statut_execution": { "enum": ["succes", "erreur"] },
    "date_execution": { "type": "string", "format": "date-time" },
    "fichiers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "qr_svg_url": { "type": ["string", "null"], "format": "uri" },
        "qr_png_url": { "type": ["string", "null"], "format": "uri" },
        "etiquette_svg_url": { "type": ["string", "null"], "format": "uri" },
        "pdf_impression_url": { "type": ["string", "null"], "format": "uri" }
      }
    },
    "erreur": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1, "maxLength": 80 },
        "message": { "type": "string", "minLength": 1, "maxLength": 4000 },
        "etape": { "type": ["string", "null"], "maxLength": 100 }
      }
    }
  }
}
